{
  "name": "dawn",
  "version": "1.0.0",
  "description": "Shopify Dawn theme with Tailwind CSS",
  "private": true,
  "scripts": {
    "dev": "concurrently --kill-others \"npm run shopify:dev\" \"npm run tailwind:watch\"",
    "build": "tailwindcss -i ./src/tailwind.css -o ./assets/tailwind.css --minify",
    "shopify:dev": "shopify theme dev --environment development",
    "tailwind:watch": "tailwindcss -i ./src/tailwind.css -o ./assets/tailwind.css --watch"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17"
  }
}
